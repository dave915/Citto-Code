{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "electron/preload.ts",
    "electron/preload/**/*.ts",
    "electron/persistence-types.ts",
    "electron/secretary/actions.ts",
    "electron/secretary/routes.ts",
    "electron/secretary/types.ts"
  ]
}
